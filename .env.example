# TLC Ecosystem - Shared Environment Configuration

# ============================================
# CROSS-PLATFORM INTEGRATION
# ============================================

# Shared Backend API (same Supabase project as this app)
VITE_SHARED_API_URL=${VITE_SUPABASE_URL}/functions/v1

# Already configured in this project
# VITE_SUPABASE_URL=...
# VITE_SUPABASE_ANON_KEY=...

# Enable/disable cross-platform features (false until backend ready)
VITE_ENABLE_CROSS_PLATFORM=false

# API timeout (milliseconds)
VITE_API_TIMEOUT=10000

# ============================================
# PULSE CYCLE PRO SPECIFIC (Keep existing)
# ============================================

# DexScreener API (if needed)
VITE_DEXSCREENER_API_KEY=

# ============================================
# DEVELOPMENT ONLY
# ============================================

# Enable detailed API logging
VITE_DEBUG_API=false

# Mock API responses for testing
VITE_MOCK_API_RESPONSES=true
